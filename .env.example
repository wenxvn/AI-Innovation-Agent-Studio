# ============================================
# AI Innovation Agent Studio Environment Variables
# ============================================

# Frontend (apps/web)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Innovation Agent Studio

# Backend (apps/api)
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys (optional for Phase 1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# GitHub (optional)
GITHUB_TOKEN=

# MinIO/S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-studio
