#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/wenxvn/AI Innovation Agent Studio/node_modules/.pnpm/autoprefixer@10.5.0_postcss@8.5.14/node_modules/autoprefixer/node_modules:/mnt/d/wenxvn/AI Innovation Agent Studio/node_modules/.pnpm/autoprefixer@10.5.0_postcss@8.5.14/node_modules:/mnt/d/wenxvn/AI Innovation Agent Studio/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/wenxvn/AI Innovation Agent Studio/node_modules/.pnpm/autoprefixer@10.5.0_postcss@8.5.14/node_modules/autoprefixer/node_modules:/mnt/d/wenxvn/AI Innovation Agent Studio/node_modules/.pnpm/autoprefixer@10.5.0_postcss@8.5.14/node_modules:/mnt/d/wenxvn/AI Innovation Agent Studio/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../autoprefixer/bin/autoprefixer" "$@"
else
  exec node  "$basedir/../autoprefixer/bin/autoprefixer" "$@"
fi
